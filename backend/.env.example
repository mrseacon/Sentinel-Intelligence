# Sentinel backend – Umgebungsvariablen (Referenz).
#
# WICHTIG: v1 lädt KEINE .env-Dateien automatisch (bewusst kein
# python-dotenv). Diese Datei dokumentiert nur, welche Variablen die
# Prozess-Umgebung setzen kann – z.B. per `export` oder im Deploy-Panel.

# --- KI-Funktionen (sentinel_core/ai) ---------------------------------
# Kostenschranke für das öffentliche Repo: KI ist standardmäßig AUS.
# Erst ein explizites "true" erlaubt echte Anthropic-API-Calls – ein
# versehentlich gesetzter Key (alter lokaler Export, CI-Secret) löst
# ohne dieses Opt-in NIE einen bezahlten Call aus.
SENTINEL_AI_ENABLED=false

# Anthropic-API-Key – nur relevant, wenn SENTINEL_AI_ENABLED=true.
ANTHROPIC_API_KEY=

# Optional: Modell-Override (Default: Claude Haiku, s. ai/llm_client.py).
# SENTINEL_LLM_MODEL=claude-haiku-4-5-20251001

# --- Frontend-Anbindung / Deploy (ARCHITECTURE §8 Deploy-Checkliste) ---
# Kommagetrennte Liste erlaubter CORS-Origins. Lokal: unnötig, main.py
# fällt ohne diese Variable auf http://localhost:3000 zurück. Produktion:
# die echte Vercel-Domain(s) setzen, z.B.
# ALLOWED_ORIGINS=https://sentinel.vercel.app
ALLOWED_ORIGINS=

# Kommagetrennte Liste vertrauenswürdiger Hosts (TrustedHostMiddleware,
# F8). Lokal: unnötig, Default ist "*" (keine Einschränkung). Produktion:
# die echte Backend-Domain setzen, z.B.
# TRUSTED_HOSTS=sentinel-api.up.railway.app
TRUSTED_HOSTS=

# Absoluter Pfad für den Stress-Replay-Preiscache (F5: der Default in
# stress/replay.py ist bereits absolut, an den Code-Ort gebunden — diese
# Variable ist nur für Deploy-Umgebungen mit einem separaten
# beschreibbaren Volume nötig, z.B. ein persistentes Railway-Volume statt
# des ephemeren Container-Dateisystems).
# STRESS_CACHE_DIR=/data/stress-cache
