# Sentinel backend – Umgebungsvariablen (Referenz).
#
# WICHTIG: v1 lädt KEINE .env-Dateien automatisch (bewusst kein
# python-dotenv). Diese Datei dokumentiert nur, welche Variablen die
# Prozess-Umgebung setzen kann – z.B. per `export` oder im Deploy-Panel.

# --- KI-Funktionen (sentinel_core/ai) ---------------------------------
# Kostenschranke für das öffentliche Repo: KI ist standardmäßig AUS.
# Erst ein explizites "true" erlaubt echte Anthropic-API-Calls – ein
# versehentlich gesetzter Key (alter lokaler Export, CI-Secret) löst
# ohne dieses Opt-in NIE einen bezahlten Call aus.
SENTINEL_AI_ENABLED=false

# Anthropic-API-Key – nur relevant, wenn SENTINEL_AI_ENABLED=true.
ANTHROPIC_API_KEY=

# Optional: Modell-Override (Default: Claude Haiku, s. ai/llm_client.py).
# SENTINEL_LLM_MODEL=claude-haiku-4-5-20251001

# --- Frontend-Anbindung ------------------------------------------------
# CORS ist in sentinel_api/main.py auf http://localhost:3000 fixiert;
# beim Deployment anpassen (Deploy-Checkliste ARCHITECTURE §8).
