# Kopieren nach .env.local (das ist bereits in .gitignore) und anpassen.
# Basis-URL der lokalen FastAPI-Instanz (siehe backend/README bzw.
# CLAUDE.md "Befehle" — uvicorn läuft standardmäßig auf Port 8000).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Produktion (Vercel-Projekteinstellungen, nicht hier): auf die echte
# Railway/Render-URL des Backends setzen, z.B.
# NEXT_PUBLIC_API_URL=https://sentinel-api.up.railway.app
# — und dieselbe Domain als ALLOWED_ORIGINS im Backend eintragen
# (backend/.env.example), sonst blockt CORS den Request.
